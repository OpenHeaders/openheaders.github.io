---
import { Image } from 'astro:assets';
import logo from '../assets/logo.svg';
---
<!-- Sticky header -->
<header id="site-header" class="fixed top-0 left-0 right-0 z-50 border-b border-transparent transition-all duration-300">
  <nav class="max-w-[1200px] mx-auto px-7 h-[68px] flex items-center justify-between">

    <!-- Logo -->
    <a href="#hero" class="flex items-center gap-2.5 no-underline text-tx font-display font-bold text-[.9375rem] tracking-tight">
      <Image src={logo} alt="OpenHeaders" width={26} height={26} class="rounded-sm" loading="eager" />
      OpenHeaders
    </a>

    <!-- Nav links -->
    <ul id="navLinks" class="nav-links flex items-center gap-7 list-none">
      <li><a href="#features"  class="text-tx-2 no-underline text-sm hover:text-tx transition-colors">Features</a></li>
      <li><a href="#use-cases"  class="text-tx-2 no-underline text-sm hover:text-tx transition-colors">Use Cases</a></li>
      <li><a href="#comparison" class="text-tx-2 no-underline text-sm hover:text-tx transition-colors">Why Us</a></li>
      <li>
        <a href="https://docs.openheaders.io" target="_blank" rel="noopener noreferrer"
           class="text-tx-2 no-underline text-sm hover:text-tx transition-colors flex items-center gap-1">
          Docs
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-40"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
      </li>
      <li><a href="#pricing"  class="text-tx-2 no-underline text-sm hover:text-tx transition-colors">Pricing</a></li>
      <li>
        <a href="https://github.com/OpenHeaders/open-headers-app" target="_blank" rel="noopener noreferrer"
           class="gh-stars flex items-center gap-1.5 text-tx-2 no-underline text-sm hover:text-tx transition-colors border border-bd rounded-sm px-2.5 py-1 hover:border-bd-hi">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" style="opacity:.55">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" class="text-amber-400"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <span id="gh-star-count" class="font-mono text-xs">Star</span>
        </a>
      </li>
    </ul>

    <!-- Right side -->
    <div class="flex items-center gap-2.5">
      <!-- Theme toggle -->
      <button id="themeToggle" aria-label="Toggle theme"
              class="theme-toggle border border-bd rounded-sm p-[7px] cursor-pointer text-tx-2 hover:border-bd-hi hover:text-tx bg-transparent transition-all">
        <!-- Sun (shown in dark mode) -->
        <svg class="sun-icon hidden w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Moon (shown in light mode) -->
        <svg class="moon-icon w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
        </svg>
      </button>

      <a id="nav-download" href="#download"
         class="nav-dl-btn hidden md:inline-flex items-center gap-1.5 px-4 py-2 rounded-sm text-sm font-medium bg-accent text-white border border-accent hover:bg-accent-hi hover:border-accent-hi hover:shadow-[0_0_28px_var(--c-accentglo),0_4px_12px_rgba(0,0,0,.2)] hover:-translate-y-px transition-all no-underline whitespace-nowrap leading-none">
        Download
      </a>
      <button id="mobileMenuToggle" aria-label="Menu"
              class="mobile-toggle hidden md:!hidden border border-bd rounded-sm p-[7px] cursor-pointer text-tx-2 hover:border-bd-hi hover:text-tx bg-transparent transition-all">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </nav>
</header>

<style>
  header.scrolled {
    background: var(--c-navbg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-color: var(--c-bd);
  }

  /* Theme toggle icon visibility — :global needed because .dark is on <html> */
  :global(.dark) .sun-icon  { display: block; }
  :global(.dark) .moon-icon { display: none; }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
      position: fixed;
      top: 68px;
      left: 0;
      right: 0;
      background: var(--c-navbg);
      backdrop-filter: blur(20px);
      flex-direction: column;
      gap: 0;
      border-bottom: 1px solid var(--c-bd);
      padding: 8px 0;
    }
    .nav-links.active { display: flex; }
    .nav-links li { width: 100%; }
    .nav-links a { display: flex; padding: 12px 24px; border-bottom: 1px solid var(--c-bd); font-size: .9375rem; }
    .nav-links li:last-child a { border-bottom: none; }
    .mobile-toggle { display: flex !important; align-items: center; }
  }
</style>

<script>
  // Theme toggle
  const toggle = document.getElementById('themeToggle');
  toggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('oh-theme', isDark ? 'dark' : 'light');
  });

  // Scroll header
  window.addEventListener('scroll', () => {
    document.getElementById('site-header')?.classList.toggle('scrolled', window.scrollY > 10);
  });

  // Mobile nav
  document.getElementById('mobileMenuToggle')?.addEventListener('click', () => {
    document.getElementById('navLinks')?.classList.toggle('active');
  });
  document.querySelectorAll('.nav-links a').forEach(a =>
    a.addEventListener('click', () => document.getElementById('navLinks')?.classList.remove('active'))
  );

  // Smooth scroll for anchor links (skip download buttons)
  document.querySelectorAll('a[href^="#"]').forEach(a => {
    if (['hero-download','hero-extension','primary-download'].includes(a.id)) return;
    a.addEventListener('click', function(this: HTMLAnchorElement, e) {
      const h = this.getAttribute('href');
      if (h && h !== '#' && h.length > 1) {
        const t = document.querySelector(h);
        if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
      }
    });
  });

  // Fetch GitHub stars
  (async () => {
    const CACHE_KEY = 'oh-gh-stars';
    const CACHE_TTL = 60 * 60 * 1000; // 1 hour
    try {
      const cached = localStorage.getItem(CACHE_KEY);
      let count = null;
      if (cached) {
        const { stars, ts } = JSON.parse(cached);
        if (Date.now() - ts < CACHE_TTL && stars != null) count = stars;
      }
      if (count == null) {
        const res = await fetch('https://api.github.com/repos/OpenHeaders/open-headers-app');
        const data = await res.json();
        if (data.stargazers_count != null) {
          count = data.stargazers_count;
          localStorage.setItem(CACHE_KEY, JSON.stringify({ stars: count, ts: Date.now() }));
        }
      }
      if (count != null) {
        const fmt = count >= 1000 ? (count / 1000).toFixed(1).replace(/\.0$/, '') + 'k' : String(count);
        document.querySelectorAll('#gh-star-count').forEach(el => { el.textContent = fmt; });
      }
    } catch {}
  })();
</script>
