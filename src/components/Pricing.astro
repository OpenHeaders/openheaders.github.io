<!-- Pricing section -->
<section class="relative py-24 border-t border-b border-bd overflow-hidden" id="pricing">
  <!-- Glow -->
  <div class="absolute -top-[200px] left-1/2 -translate-x-1/2 w-[800px] h-[600px] pointer-events-none" style="background:radial-gradient(ellipse at center, var(--c-glow) 0%, transparent 70%)"></div>

  <div class="max-w-[1200px] mx-auto px-7 relative z-[1]">
    <div class="flex items-center gap-2 font-mono text-[.6875rem] font-medium text-accent uppercase tracking-[.12em] mb-2.5 before:content-['//'] before:opacity-50">pricing</div>
    <h2 class="font-display text-[clamp(1.75rem,4vw,2.75rem)] font-bold tracking-tight text-tx leading-[1.1]">Free &amp; open source. <span class="text-tx-3">No catches.</span></h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 items-start mt-14">
      <!-- Price card -->
      <div class="bg-bg-2 border border-bd rounded-lg overflow-hidden hover:border-bd-hi transition-colors">
        <div class="px-9 pt-9 pb-7 border-b border-bd" style="background:linear-gradient(135deg, var(--c-accentdim) 0%, transparent 60%)">
          <div class="font-mono text-[.6875rem] text-accent uppercase tracking-[.1em] mb-4">Open source — MIT license</div>
          <div class="flex items-baseline gap-1">
            <span class="text-2xl text-tx-2 font-light">$</span>
            <span class="font-display text-[4rem] font-extrabold tracking-[-0.05em] text-tx leading-none">0</span>
          </div>
        </div>
        <div class="px-9 pt-7 pb-9">
          <h4 class="font-mono text-[.6875rem] text-tx-3 uppercase tracking-[.1em] mb-5">everything included</h4>
          <ul class="flex flex-col gap-3.5 list-none p-0">
            {[
              'Unlimited modification rules',
              'Unlimited HTTP / Env / File sources',
              'Unlimited session recordings',
              'Team workspace collaboration',
              'Personal and commercial use',
              'Community support (chat & email)',
              'No telemetry or data collection',
            ].map(item => (
              <li class="flex items-center gap-2.5 text-sm text-tx-2 font-light">
                <span class="w-[18px] h-[18px] flex-shrink-0 rounded grid place-items-center text-success" style="background:var(--c-successdim);border:1px solid var(--c-successbd)">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Enterprise CTA -->
      <div class="bg-bg-2 border border-bd rounded-lg px-9 py-10 flex flex-col justify-between transition-colors" style="border-color:var(--c-bd)">
        <div>
          <div class="font-mono text-[.6875rem] text-accent uppercase tracking-[.1em] mb-4">enterprise / custom</div>
          <h3 class="font-display text-[1.375rem] font-bold tracking-tight text-tx mb-3">Need something more?</h3>
          <p class="text-tx-2 text-[.9rem] font-light leading-[1.7] mb-7">We're continuously improving OpenHeaders based on real developer feedback. Custom features, priority support, or a private deployment — reach out.</p>
        </div>
        <div class="flex items-center gap-3 flex-wrap">
          <button id="copy-email-btn"
                  class="inline-flex items-center gap-2 px-4 py-2 rounded-sm bg-transparent text-accent text-sm font-medium cursor-pointer transition-all" style="border:1px solid var(--c-accentbd)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
            Copy email address
          </button>
          <a href="https://github.com/OpenHeaders/open-headers-app/discussions" target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 px-4 py-2 rounded-sm bg-transparent text-tx-2 text-sm font-medium no-underline transition-all hover:text-tx hover:border-bdhi" style="border:1px solid var(--c-bd)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            Start a discussion
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById('copy-email-btn');
  if (btn) {
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText('contact@openheaders.io');
        const orig = btn.innerHTML;
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.innerHTML = orig; }, 2000);
      } catch (e) { console.error('Failed to copy:', e); }
    });
  }
</script>
