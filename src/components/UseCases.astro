<!-- Use Cases section -->
<section class="py-28" id="use-cases">
  <div class="max-w-[1200px] mx-auto px-7 relative z-[1]">

    <!-- Header -->
    <div class="text-center mb-[72px]">
      <div class="flex items-center gap-2 justify-center font-mono text-[.6875rem] font-medium text-accent uppercase tracking-[.12em] mb-2.5 before:content-['//'] before:opacity-50">use cases</div>
      <h2 class="font-display text-[clamp(1.75rem,4vw,2.75rem)] font-bold tracking-tight text-tx leading-[1.1]">Built for the way<br>developers actually work</h2>
      <p class="text-tx-2 text-[1.0625rem] font-light max-w-[480px] mx-auto mt-4 leading-7">Real workflows teams use OpenHeaders for every day.</p>
    </div>

    <div class="uc-grid">

      <!-- 1: Local dev against staging -->
      <div class="uc-card">
        <div class="uc-card-header">
          <div class="uc-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <span class="uc-role">Developer</span>
        </div>
        <h3>Local dev against a staging API</h3>
        <p>Inject auth tokens and custom headers on every request — no <code>.env</code> edits, no proxy, no server restart.</p>
        <div class="uc-snippet">
          <span class="snip-key">Authorization</span><span class="snip-arrow">→</span><span class="snip-val">Bearer $&#123;TOKEN&#125;</span>
          <span class="snip-sep">·</span>
          <span class="snip-key">X-Tenant-ID</span><span class="snip-arrow">→</span><span class="snip-val">staging-42</span>
        </div>
        <div class="uc-tags">
          <span class="uc-tag">Header injection</span>
          <span class="uc-tag">Env file values</span>
        </div>
      </div>

      <!-- 2: QA bug reports -->
      <div class="uc-card">
        <div class="uc-card-header">
          <div class="uc-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
          </div>
          <span class="uc-role">QA Engineer</span>
        </div>
        <h3>Jira bug reports with session replay</h3>
        <p>Record the exact reproduction steps and attach the exported JSON to the ticket. Dev imports it, hits play.</p>
        <div class="uc-snippet">
          <span class="snip-step">Record</span>
          <span class="snip-flow">→</span>
          <span class="snip-step">Export JSON</span>
          <span class="snip-flow">→</span>
          <span class="snip-step">Attach to Jira</span>
          <span class="snip-flow">→</span>
          <span class="snip-step">Replay</span>
        </div>
        <div class="uc-tags">
          <span class="uc-tag">Session recording</span>
          <span class="uc-tag">JSON export</span>
        </div>
      </div>

      <!-- 3: Team rule sync -->
      <div class="uc-card">
        <div class="uc-card-header">
          <div class="uc-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 01-9 9"/></svg>
          </div>
          <span class="uc-role">Team Lead</span>
        </div>
        <h3>Rule sets synced via Git</h3>
        <p>Commit header rules to a shared repo. Everyone pulls the latest config — no Slack threads, no stale wikis.</p>
        <div class="uc-snippet">
          <span class="snip-key">git pull</span><span class="snip-arrow">→</span><span class="snip-val">rules in sync</span>
          <span class="snip-sep">·</span>
          <span class="snip-key">invite link</span><span class="snip-arrow">→</span><span class="snip-val">teammate joins</span>
        </div>
        <div class="uc-tags">
          <span class="uc-tag">Git sync</span>
          <span class="uc-tag">Team workspaces</span>
        </div>
      </div>

      <!-- 4: Simulating API failures -->
      <div class="uc-card">
        <div class="uc-card-header">
          <div class="uc-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
          </div>
          <span class="uc-role">Developer</span>
        </div>
        <h3>Simulating failures without a mock backend</h3>
        <p>Block an endpoint and inject a custom error response. Test retry logic and error UI in seconds.</p>
        <div class="uc-snippet">
          <span class="snip-key">POST /charge</span><span class="snip-arrow">→</span><span class="snip-val snip-err">503 blocked</span>
        </div>
        <div class="uc-tags">
          <span class="uc-tag">Request blocking</span>
          <span class="uc-tag">Response override</span>
        </div>
      </div>

      <!-- 5: Security audit -->
      <div class="uc-card">
        <div class="uc-card-header">
          <div class="uc-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <span class="uc-role">Security Engineer</span>
        </div>
        <h3>Auditing security header degradation</h3>
        <p>Strip CSP or HSTS from responses in-browser and observe how your app behaves — no flags, no proxy.</p>
        <div class="uc-snippet">
          <span class="snip-key">Strict-Transport-Security</span><span class="snip-arrow">→</span><span class="snip-val snip-err">stripped</span>
        </div>
        <div class="uc-tags">
          <span class="uc-tag">Response headers</span>
          <span class="uc-tag">Zero telemetry</span>
        </div>
      </div>

      <!-- 6: Onboarding demo -->
      <div class="uc-card">
        <div class="uc-card-header">
          <div class="uc-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 10l4.553-2.277A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14"/><rect x="3" y="6" width="12" height="12" rx="2"/></svg>
          </div>
          <span class="uc-role">DevRel / Product</span>
        </div>
        <h3>Onboarding demos with real network context</h3>
        <p>Record a product walkthrough with live network and console data. Export as MP4 or shareable JSON.</p>
        <div class="uc-snippet">
          <span class="snip-step">Record</span>
          <span class="snip-flow">→</span>
          <span class="snip-step">MP4 share</span>
          <span class="snip-sep">·</span>
          <span class="snip-step">JSON</span>
          <span class="snip-flow">→</span>
          <span class="snip-step">step-through replay</span>
        </div>
        <div class="uc-tags">
          <span class="uc-tag">Session recording</span>
          <span class="uc-tag">MP4 / JSON export</span>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* ── Animate-in ──────────────────────────────── */
  .uc-grid {
    opacity: 0; transform: translateY(28px);
    transition: opacity .7s ease, transform .7s ease;
  }
  .uc-grid.in-view { opacity: 1; transform: translateY(0); }

  /* ── Grid ────────────────────────────────────── */
  .uc-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px;
  }

  /* ── Card ────────────────────────────────────── */
  .uc-card {
    background: var(--c-bg2); border: 1px solid var(--c-bd); border-radius: 18px;
    padding: 32px; display: flex; flex-direction: column; gap: 14px;
    transition: border-color .3s, background .3s;
  }
  .uc-card:hover { border-color: var(--c-bdhi); background: var(--c-bg3); }
  .uc-card-header { display: flex; align-items: center; gap: 10px; }

  /* ── Icon ────────────────────────────────────── */
  .uc-icon {
    width: 36px; height: 36px; background: var(--c-accentdim);
    border: 1px solid var(--c-accentbd); border-radius: 8px;
    display: grid; place-items: center; color: var(--c-accent);
    flex-shrink: 0;
  }

  /* ── Role pill ───────────────────────────────── */
  .uc-role {
    display: inline-flex; align-items: center;
    padding: 3px 10px; border-radius: 100px;
    background: var(--c-accentdim); border: 1px solid var(--c-accentbd);
    font-family: 'JetBrains Mono', monospace; font-size: .625rem;
    color: var(--c-accenthi); letter-spacing: .06em; text-transform: uppercase;
    width: fit-content;
  }

  /* ── Title ───────────────────────────────────── */
  .uc-card h3 {
    font-family: 'Inter', -apple-system, sans-serif;
    font-size: 1rem; font-weight: 700;
    letter-spacing: -.02em; color: var(--c-tx); line-height: 1.3; margin: 0;
  }

  /* ── Body ────────────────────────────────────── */
  .uc-card p {
    color: var(--c-tx2); font-size: .8125rem; font-weight: 300;
    line-height: 1.65; margin: 0; flex: 1;
  }
  .uc-card code {
    font-family: 'JetBrains Mono', monospace; font-size: .8em;
    color: var(--c-accenthi); background: var(--c-accentdim);
    padding: 1px 5px; border-radius: 4px;
  }

  /* ── Scenario snippet ────────────────────────── */
  .uc-snippet {
    display: flex; flex-wrap: wrap; align-items: center; gap: 5px;
    background: var(--c-bg3); border: 1px solid var(--c-bd); border-radius: 10px;
    padding: 10px 14px;
    font-family: 'JetBrains Mono', monospace; font-size: .6875rem;
  }
  .snip-key   { color: var(--c-tx2); }
  .snip-arrow { color: var(--c-tx3); }
  .snip-val   { color: var(--c-accenthi); }
  .snip-err   { color: #f87171; }
  .snip-sep   { color: var(--c-tx3); margin: 0 2px; }
  .snip-step  { color: var(--c-tx); background: var(--c-bg4); border: 1px solid var(--c-bd); border-radius: 5px; padding: 2px 7px; }
  .snip-flow  { color: var(--c-tx3); }

  /* ── Feature tags ────────────────────────────── */
  .uc-tags {
    display: flex; flex-wrap: wrap; gap: 6px;
    padding-top: 14px; border-top: 1px solid var(--c-bd); margin-top: auto;
  }
  .uc-tag {
    font-family: 'JetBrains Mono', monospace; font-size: .6rem;
    color: var(--c-tx3); background: transparent;
    border: 1px solid var(--c-bd); border-radius: 100px;
    padding: 2px 8px; letter-spacing: .02em;
  }

  /* ── Responsive ──────────────────────────────── */
  @media (max-width: 1024px) {
    .uc-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 640px) {
    .uc-grid { grid-template-columns: 1fr; }
    .uc-card { padding: 24px; }
  }
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('in-view'); obs.unobserve(e.target); }
    });
  }, { threshold: 0.07 });
  document.querySelectorAll('.uc-grid').forEach(el => obs.observe(el));
</script>
