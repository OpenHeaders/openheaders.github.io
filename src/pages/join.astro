---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import logo from '../assets/logo.svg';
---

<Base title="Join Team Workspace — OpenHeaders" description="Join a team workspace in OpenHeaders">
  <div class="join-wrap">
    <div class="join-card" id="join-card">

      <!-- Header -->
      <div class="join-header">
        <Image src={logo} alt="OpenHeaders" width={32} height={32} loading="eager" class="rounded-sm" />
        <span class="brand">OpenHeaders</span>
      </div>

      <!-- Progress -->
      <div id="step-progress" class="progress" style="display:none">
        <div class="progress-step" data-step="invite">
          <span class="progress-dot"></span>
          <span class="progress-label">Invite</span>
        </div>
        <span class="progress-arrow">›</span>
        <div class="progress-step" data-step="install">
          <span class="progress-dot"></span>
          <span class="progress-label">Install</span>
        </div>
        <span class="progress-arrow">›</span>
        <div class="progress-step" data-step="join">
          <span class="progress-dot"></span>
          <span class="progress-label">Join</span>
        </div>

      </div>

      <!-- Step: invite -->
      <div id="step-invite" class="step" style="display:none">
        <div class="invite-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
        </div>
        <p class="invite-label">You've been invited to join</p>
        <h1 class="invite-name" id="workspace-name"></h1>
        <p class="invite-by" id="invite-by"></p>

        <div id="app-detected-badge" class="app-detected-badge" style="display:none">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          App detected
        </div>

        <div class="step-actions">
          <button class="btn-primary" id="btn-need-install">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download &amp; Join
          </button>
          <button class="btn-ghost" id="btn-open-app">I already have OpenHeaders installed</button>
        </div>
      </div>

      <!-- Step: opening -->
      <div id="step-opening" class="step" style="display:none">
        <div class="spinner"></div>
        <h2 class="step-title">Opening OpenHeaders…</h2>
        <p class="step-sub">Check if a dialog appeared in your browser asking to open the app.</p>
        <div class="step-actions" style="margin-top:2rem">
          <button class="btn-ghost" id="btn-open-retry">Try again</button>
          <button class="btn-ghost small" id="btn-not-installed">App not installed? Download it</button>
        </div>
      </div>

      <!-- Step: success -->
      <div id="step-success" class="step" style="display:none">
        <div class="success-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <h2 class="step-title">You're in!</h2>
        <p class="step-sub">The workspace is opening in OpenHeaders. You can close this tab.</p>
      </div>

      <!-- Step: download / install -->
      <div id="step-download" class="step" style="display:none">
        <h2 class="step-title">Install OpenHeaders</h2>

        <a id="primary-download" href="https://github.com/OpenHeaders/open-headers-app/releases/latest" class="btn-primary dl-btn" download>
          <img id="primary-icon" src="/assets/icons/apple.svg" alt="" width="18" height="18" style="filter:brightness(0) invert(1)" />
          <span class="dl-btn-text">
            <span class="dl-btn-main">Download Desktop App</span>
            <span class="dl-btn-sub" id="primary-text">Detecting platform…</span>
          </span>
        </a>

        <details class="dl-other">
          <summary>Other platforms &amp; architectures</summary>
          <div id="other-downloads" class="dl-list"></div>
        </details>

        <div id="install-steps" class="install-steps"></div>

        <button class="btn-primary" id="btn-installed-next" style="margin-top:1rem">
          I've installed it — Continue
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>

      <!-- Step: join -->
      <div id="step-join" class="step" style="display:none">
        <h2 class="step-title">Join Workspace</h2>
        <p class="step-sub">OpenHeaders is installed and running. Click below to join the workspace.</p>
        <button class="btn-primary" id="btn-open-after-install">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
          Join Workspace
        </button>
      </div>

      <!-- Step: error -->
      <div id="step-error" class="step" style="display:none">
        <div class="error-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <h2 class="step-title">Invalid invite</h2>
        <p class="step-sub" id="error-msg">This invite link is invalid or has expired.</p>
        <a href="https://openheaders.io" class="btn-ghost" style="margin-top:1.5rem;display:inline-flex">Go to openheaders.io</a>
      </div>

      <div class="join-footer">
        Privacy-first, <a href="https://github.com/OpenHeaders" target="_blank" rel="noopener noreferrer">open source</a> browser toolkit
      </div>
    </div>
  </div>

  <!-- Pako for gzip decompression -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/pako/2.1.0/pako.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>

  <script>
    import { detectPlatform } from '../scripts/platform-detection.js';

    let inviteData: Record<string, any> | null = null;
    let latestVersion: string | null = null;

    // ── Helpers ──────────────────────────────────────────────────────────────

    function show(id: string) {
      document.querySelectorAll('.step').forEach(s => ((s as HTMLElement).style.display = 'none'));
      const el = document.getElementById(id);
      if (el) el.style.display = 'block';
    }

    function setProgress(active: string, done: string[] = []) {
      const prog = document.getElementById('step-progress');
      if (!prog) return;
      prog.style.display = 'flex';
      prog.querySelectorAll<HTMLElement>('.progress-step').forEach(s => {
        const key = s.dataset.step!;
        s.classList.toggle('is-active', key === active);
        s.classList.toggle('is-done', done.includes(key));
      });
    }

    function buildProtocolUrl(data: Record<string, any>) {
      const payload = { version: '3.0.0', action: 'team-invite', data };
      try {
        const str = JSON.stringify(payload);
        const compressed = (window as any).pako.gzip(str);
        const bin = Array.from(compressed, (b: number) => String.fromCharCode(b)).join('');
        const b64 = btoa(bin).replace(/\+/g, '-').replace(/\//g, '_').replace(/=/g, '');
        return `openheaders://open?payload=${b64}`;
      } catch {
        const b64 = btoa(JSON.stringify(payload)).replace(/\+/g, '-').replace(/\//g, '_').replace(/=/g, '');
        return `openheaders://open?payload=${b64}`;
      }
    }

    // ── Version & downloads ──────────────────────────────────────────────────

    async function fetchLatestVersion() {
      const CACHE_KEY = 'oh-latest-version';
      const CACHE_TTL = 60 * 60 * 1000;
      try {
        const cached = localStorage.getItem(CACHE_KEY);
        if (cached) {
          const { version, ts } = JSON.parse(cached);
          if (Date.now() - ts < CACHE_TTL && version) { latestVersion = version; return; }
        }
        const res = await fetch('https://api.github.com/repos/OpenHeaders/open-headers-app/releases/latest');
        const data = await res.json();
        if (data.tag_name) {
          latestVersion = data.tag_name.replace('v', '');
          localStorage.setItem(CACHE_KEY, JSON.stringify({ version: latestVersion, ts: Date.now() }));
        }
      } catch {}
      if (!latestVersion) latestVersion = '3.4.1';
    }

    function getDownloadUrl(os: string, arch: string, variant?: string) {
      if (!latestVersion) return null;
      const v = latestVersion;
      const base = `https://github.com/OpenHeaders/open-headers-app/releases/download/v${v}/`;
      const map: Record<string, { url: string; name: string; icon: string }> = {
        'mac-x64':              { url: `${base}OpenHeaders-${v}-mac-x64.dmg`,     name: 'macOS Intel',          icon: '/assets/icons/apple.svg' },
        'mac-arm64':            { url: `${base}OpenHeaders-${v}-mac-arm64.dmg`,   name: 'macOS Apple Silicon',  icon: '/assets/icons/apple.svg' },
        'windows-x64':          { url: `${base}OpenHeaders-${v}-Setup.exe`,       name: 'Windows with Git',     icon: '/assets/icons/windows.svg' },
        'windows-x64-nogit':    { url: `${base}OpenHeaders-${v}-Setup-NoGit.exe`, name: 'Windows without Git',  icon: '/assets/icons/windows.svg' },
        'linux-appimage-x64':   { url: `${base}OpenHeaders-${v}-x64.AppImage`,    name: 'Linux AppImage x64',   icon: '/assets/icons/linux.svg' },
        'linux-appimage-arm64': { url: `${base}OpenHeaders-${v}-arm64.AppImage`,  name: 'Linux AppImage ARM64', icon: '/assets/icons/linux.svg' },
        'linux-deb-x64':        { url: `${base}open-headers_${v}_amd64.deb`,      name: 'Debian/Ubuntu x64',    icon: '/assets/icons/linux.svg' },
        'linux-deb-arm64':      { url: `${base}open-headers_${v}_arm64.deb`,      name: 'Debian/Ubuntu ARM64',  icon: '/assets/icons/linux.svg' },
        'linux-rpm-x64':        { url: `${base}open-headers-${v}.x86_64.rpm`,     name: 'Fedora/RHEL x64',      icon: '/assets/icons/linux.svg' },
        'linux-rpm-arm64':      { url: `${base}open-headers-${v}.aarch64.rpm`,    name: 'Fedora/RHEL ARM64',    icon: '/assets/icons/linux.svg' },
      };
      return map[variant || `${os}-${arch}`] || null;
    }

    function renderInstallSteps(os: string) {
      const steps: Record<string, string[]> = {
        mac:             ['Open the .dmg file', 'Drag & drop OpenHeaders → Applications', 'Launch from Applications'],
        windows:         ['Double-click the installer', 'App installs & launches automatically'],
        'linux-appimage':['chmod +x OpenHeaders-*.AppImage', 'Run: sudo ./install-open-headers.sh', 'Launch from app menu'],
        'linux-deb':     ['sudo apt install ./open-headers_*.deb', 'Launch from app menu'],
        'linux-rpm':     ['sudo rpm -i open-headers-*.rpm', 'Launch from app menu'],
        linux:           ['Make executable & run installer', 'Launch from app menu'],
      };
      const list = steps[os] || steps.linux;
      const stepsHtml = list.map((s, i) =>
        `<div class="is-item"><span class="is-num">${i + 1}</span><span class="is-label">${s}</span></div>${i < list.length - 1 ? '<div class="is-arrow">↓</div>' : ''}`
      ).join('');
      const el = document.getElementById('install-steps');
      if (el) el.innerHTML = `<div class="is-row">${stepsHtml}</div>`;
    }

    async function populateDownloads() {
      const plat = await detectPlatform();
      await fetchLatestVersion();

      let primary = null;
      if (plat.os === 'mac') primary = getDownloadUrl('mac', plat.arch);
      else if (plat.os === 'windows') primary = getDownloadUrl('windows', 'x64');
      else if (plat.os.includes('linux')) {
        if (plat.os === 'linux-deb') primary = getDownloadUrl('linux-deb', plat.arch);
        else if (plat.os === 'linux-rpm') primary = getDownloadUrl('linux-rpm', plat.arch);
        else primary = getDownloadUrl('linux-appimage', plat.arch);
      }

      if (primary) {
        const btn = document.getElementById('primary-download') as HTMLAnchorElement;
        const icon = document.getElementById('primary-icon') as HTMLImageElement;
        btn.href = primary.url;
        btn.setAttribute('download', '');
        icon.src = primary.icon;
        document.getElementById('primary-text')!.textContent = `${primary.name}${latestVersion ? ` · v${latestVersion}` : ''}`;
      }

      renderInstallSteps(plat.os);

      const all = [
        getDownloadUrl('mac', 'arm64'), getDownloadUrl('mac', 'x64'),
        getDownloadUrl('windows', 'x64'), getDownloadUrl('windows', 'x64', 'windows-x64-nogit'),
        getDownloadUrl('linux-appimage', 'x64'), getDownloadUrl('linux-appimage', 'arm64'),
        getDownloadUrl('linux-deb', 'x64'), getDownloadUrl('linux-deb', 'arm64'),
        getDownloadUrl('linux-rpm', 'x64'), getDownloadUrl('linux-rpm', 'arm64'),
      ].filter((d): d is NonNullable<typeof d> => !!d && (!primary || d.url !== primary.url));

      document.getElementById('other-downloads')!.innerHTML = all.map(opt =>
        `<a href="${opt.url}" class="download-option" download>
          <div class="info"><img src="${opt.icon}" alt="" width="16" height="16" class="icon-inverted" loading="lazy"><span class="name">${opt.name}</span>${latestVersion ? `<span class="size">${latestVersion}</span>` : ''}</div>
        </a>`
      ).join('');
    }

    // ── App open flow ────────────────────────────────────────────────────────

    function silentProbe() {
      if (!inviteData) return;
      const iframe = document.createElement('iframe');
      iframe.style.display = 'none';
      iframe.src = buildProtocolUrl(inviteData);

      const onBlur = () => {
        cleanup();
        // App detected — promote "Open in app" to primary
        const btnOpen = document.getElementById('btn-open-app');
        const btnInstall = document.getElementById('btn-need-install');
        if (btnOpen) { btnOpen.className = 'btn-primary'; btnOpen.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg> Open in OpenHeaders'; }
        if (btnInstall) { btnInstall.className = 'btn-ghost'; btnInstall.innerHTML = 'Download instead'; }
        const badge = document.getElementById('app-detected-badge');
        if (badge) badge.style.display = 'flex';
      };
      const cleanup = () => {
        window.removeEventListener('blur', onBlur);
        clearTimeout(timer);
        iframe.remove();
      };
      const timer = setTimeout(cleanup, 1500);
      window.addEventListener('blur', onBlur);
      document.body.appendChild(iframe);
    }

    function tryOpenApp() {
      if (!inviteData) return;
      show('step-opening');
      setProgress('join', ['invite', 'install']);
      const url = buildProtocolUrl(inviteData);

      const onBlur = () => {
        cleanup();
        show('step-success');
        setProgress('join', ['invite', 'install', 'join']);
      };
      const cleanup = () => {
        window.removeEventListener('blur', onBlur);
        clearTimeout(timer);
      };
      const timer = setTimeout(cleanup, 2000);
      window.addEventListener('blur', onBlur);

      window.location.href = url;
    }

    // ── Init ─────────────────────────────────────────────────────────────────

    function init() {
      const params = new URLSearchParams(window.location.search);
      const payloadParam = params.get('payload');
      if (!payloadParam) { showError('No invite found in this link.'); return; }

      try {
        let decoded: any;
        try {
          const bytes = Uint8Array.from(atob(payloadParam.replace(/-/g, '+').replace(/_/g, '/')), c => c.charCodeAt(0));
          decoded = JSON.parse((window as any).pako.ungzip(bytes, { to: 'string' }));
        } catch {
          try { decoded = JSON.parse(atob(payloadParam)); } catch { throw new Error('Invalid format'); }
        }

        if (decoded.action !== 'team-invite' || !decoded.data) { showError('This invite is not valid.'); return; }
        inviteData = decoded.data;
        if (!inviteData?.workspaceName || !inviteData?.repoUrl) { showError('This invite is missing required data.'); return; }

        // Populate invite step
        document.getElementById('workspace-name')!.textContent = inviteData.workspaceName;
        const inviteBy = document.getElementById('invite-by')!;
        if (inviteData.inviterName) {
          inviteBy.textContent = `Invited by ${inviteData.inviterName}`;
        } else {
          inviteBy.style.display = 'none';
        }

        show('step-invite');
        setProgress('invite');

        // Silently probe for app
        silentProbe();

        // Wire up buttons
        document.getElementById('btn-open-app')?.addEventListener('click', tryOpenApp);

        document.getElementById('btn-need-install')?.addEventListener('click', () => {
          show('step-download');
          setProgress('install', ['invite']);
          populateDownloads();
        });

        document.getElementById('btn-open-retry')?.addEventListener('click', () => {
          const btn = document.getElementById('btn-open-retry') as HTMLButtonElement;
          const orig = btn.textContent;
          btn.textContent = 'Retrying…';
          btn.disabled = true;
          setTimeout(() => { btn.textContent = orig; btn.disabled = false; }, 2000);
          tryOpenApp();
        });

        document.getElementById('btn-not-installed')?.addEventListener('click', () => {
          show('step-download');
          setProgress('install', ['invite']);
          populateDownloads();
        });

        document.getElementById('btn-installed-next')?.addEventListener('click', () => {
          show('step-join');
          setProgress('join', ['invite', 'install']);
        });

        document.getElementById('btn-open-after-install')?.addEventListener('click', tryOpenApp);

      } catch {
        showError('This invite link appears to be invalid or corrupted.');
      }
    }

    function showError(msg: string) {
      document.getElementById('error-msg')!.textContent = msg;
      show('step-error');
    }

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
    else init();
  </script>
</Base>

<style>
  .join-wrap {
    min-height: 100vh; display: flex; align-items: center; justify-content: center;
    padding: 2rem 1.25rem;
  }
  .join-card {
    width: 100%; max-width: 440px;
    background: var(--c-bg2); border: 1px solid var(--c-bdhi);
    border-radius: 20px; padding: 2rem;
    box-shadow: 0 24px 64px var(--c-shadow);
  }

  /* Header */
  .join-header {
    display: flex; align-items: center; justify-content: center;
    gap: .5rem; margin-bottom: 2rem;
  }
  .brand { font-family: var(--font-display); font-weight: 700; font-size: .9375rem; color: var(--c-tx); }

  /* Progress indicator */
  .progress {
    display: flex; align-items: center; justify-content: center;
    gap: .5rem; margin-bottom: 1.75rem;
  }
  .progress-step { display: flex; align-items: center; gap: .375rem; }
  .progress-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--c-bd); border: 1.5px solid var(--c-bd);
    transition: all .3s;
  }
  .progress-label { font-size: .75rem; color: var(--c-tx3); font-weight: 500; transition: color .3s; }
  .progress-arrow { color: var(--c-bd); font-size: .875rem; line-height: 1; }

  .progress-step.is-active .progress-dot { background: var(--c-accent); border-color: var(--c-accent); box-shadow: 0 0 0 3px var(--c-accentdim); }
  .progress-step.is-active .progress-label { color: var(--c-accent); }
  .progress-step.is-done .progress-dot { background: var(--c-success); border-color: var(--c-success); }
  .progress-step.is-done .progress-label { color: var(--c-tx2); }
  .progress-step.is-done + .progress-arrow { color: var(--c-tx3); }

  /* Steps */
  .step { animation: fadeIn .2s ease; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }

  /* Invite step */
  .invite-icon {
    width: 56px; height: 56px; border-radius: 14px;
    background: var(--c-accentdim); border: 1px solid var(--c-accentbd);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.25rem; color: var(--c-accent);
  }
  .invite-label { text-align: center; font-size: .8125rem; color: var(--c-tx2); margin-bottom: .375rem; }
  .invite-name { text-align: center; font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; color: var(--c-tx); margin-bottom: .5rem; }
  .invite-by { text-align: center; font-size: .875rem; color: var(--c-tx2); margin-bottom: 2rem; }

  /* Step titles */
  .step-title {
    font-family: var(--font-display); font-size: 1.125rem; font-weight: 700;
    color: var(--c-tx); margin-bottom: .5rem; display: flex; align-items: center; gap: .625rem;
  }
  .step-num {
    width: 24px; height: 24px; border-radius: 50%; background: var(--c-accent);
    color: #fff; font-size: .75rem; font-weight: 700; font-family: var(--font-mono);
    display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .step-sub { font-size: .875rem; color: var(--c-tx2); margin-bottom: 1.5rem; line-height: 1.6; }

  /* Buttons */
  .step-actions { display: flex; flex-direction: column; gap: .75rem; }
  .btn-primary {
    display: flex; align-items: center; justify-content: center; gap: .625rem;
    padding: .75rem 1.25rem; border-radius: 8px;
    background: var(--c-accent); color: #fff; border: 1px solid var(--c-accent);
    font-size: .9375rem; font-weight: 500; text-decoration: none; cursor: pointer;
    transition: all .2s; width: 100%; box-sizing: border-box;
  }
  .btn-primary:hover { background: var(--c-accenthi); border-color: var(--c-accenthi); transform: translateY(-1px); }
  .btn-ghost {
    display: flex; align-items: center; justify-content: center; gap: .5rem;
    padding: .625rem 1rem; border-radius: 8px;
    background: transparent; color: var(--c-tx2); border: 1px solid var(--c-bd);
    font-size: .875rem; font-weight: 500; cursor: pointer; transition: all .2s;
    text-decoration: none; width: 100%; box-sizing: border-box;
  }
  .btn-ghost:hover { border-color: var(--c-bdhi); color: var(--c-tx); }
  .btn-ghost.small { font-size: .8125rem; padding: .5rem .875rem; color: var(--c-tx3); border-color: transparent; }
  .btn-ghost.small:hover { color: var(--c-tx2); border-color: var(--c-bd); }

  /* Download button */
  .dl-btn { text-align: left; justify-content: flex-start; margin-bottom: 1rem; }
  .dl-btn-text { display: flex; flex-direction: column; gap: 2px; }
  .dl-btn-main { font-size: .9375rem; font-weight: 500; }
  .dl-btn-sub { font-size: .75rem; opacity: .7; font-family: var(--font-mono); }

  /* Other downloads */
  .dl-other { margin-bottom: 1rem; }
  .dl-other summary { cursor: pointer; list-style: none; color: var(--c-accent); font-size: .8125rem; font-weight: 500; user-select: none; display: inline-flex; align-items: center; gap: .375rem; }
  .dl-other summary::-webkit-details-marker { display: none; }
  .dl-other summary::before { content: '\25B6'; display: inline-block; transition: transform .2s; font-size: .45rem; }
