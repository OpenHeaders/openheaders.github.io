---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import logo from '../assets/logo.svg';
import layersIcon from '../assets/icons/layers.svg';
---

<Base title="Join Team Workspace — OpenHeaders" description="Join a team workspace in OpenHeaders">
  <div class="join-container">
    <div class="join-card">
      <div class="text-center mb-6">
        <div class="flex items-center justify-center gap-2 mb-4">
          <Image src={logo} alt="OpenHeaders" width={32} height={32} loading="eager" />
          <span class="font-display font-bold text-lg text-tx">OpenHeaders</span>
        </div>
        <h1 class="font-display text-[1.75rem] font-bold text-tx mb-1">Join Team Workspace</h1>
        <p class="text-tx-2">You've been invited to collaborate</p>
      </div>

      <div id="workspace-info" class="workspace-details"></div>

      <div id="no-app-section">
        <div id="download-section" class="action-section">
          <h3 class="text-[.9375rem] font-semibold text-tx mb-3">Download OpenHeaders for <span id="detected-os"></span></h3>
          <div class="text-center">
            <a id="primary-download" href="#" class="btn-primary-join">
              <img id="primary-icon" src="" alt="" width="18" height="18" loading="eager" />
              <span>
                <span class="text-sm font-medium">Download Desktop App</span>
                <span class="text-[.6875rem] opacity-70 font-mono" id="primary-text"></span>
              </span>
            </a>
          </div>

          <details class="dl-other mt-3">
            <summary>Other download options</summary>
            <div id="other-downloads" class="dl-list"></div>
          </details>

          <details class="dl-other mt-2">
            <summary>Installation instructions</summary>
            <div id="install-instructions" class="install-instructions"></div>
          </details>
        </div>

        <div class="h-px bg-bd my-5"></div>

        <div class="text-center">
          <button class="already-installed-btn" id="already-installed-btn">
            <Image src={layersIcon} alt="App" width={18} height={18} loading="lazy" />
            <span>I already have OpenHeaders installed</span>
          </button>
        </div>
      </div>

      <div id="has-app-section" class="success-section">
        <p>
          <svg class="inline-block align-middle mr-2" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          OpenHeaders detected!
        </p>
        <a href="#" class="btn-primary-join" id="open-in-app-btn">Open in OpenHeaders</a>
      </div>

      <div class="text-center mt-6 text-[.8125rem] text-tx-2">
        Privacy-first, <a href="https://github.com/OpenHeaders" target="_blank" rel="noopener noreferrer" class="text-accent no-underline hover:underline">open source</a> browser toolkit
      </div>
    </div>
  </div>

  <!-- Pako for gzip compression -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/pako/2.1.0/pako.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>

  <script>
    import { detectPlatform } from '../scripts/platform-detection.js';

    let inviteData: Record<string, any> | null = null;
    let latestVersion: string | null = null;

    function buildProtocolUrl(data: Record<string, any>) {
      const payload = { version: '3.0.0', action: 'team-invite', data };
      try {
        const str = JSON.stringify(payload);
        const compressed = (window as any).pako.gzip(str);
        const bin = Array.from(compressed, (b: number) => String.fromCharCode(b)).join('');
        const b64 = btoa(bin).replace(/\+/g, '-').replace(/\//g, '_').replace(/=/g, '');
        return `openheaders://open?payload=${b64}`;
      } catch {
        const b64 = btoa(JSON.stringify(payload)).replace(/\+/g, '-').replace(/\//g, '_').replace(/=/g, '');
        return `openheaders://open?payload=${b64}`;
      }
    }

    function getDownloadUrl(os: string, arch: string, variant?: string) {
      const v = latestVersion || '3.0.0';
      const base = `https://github.com/OpenHeaders/open-headers-app/releases/download/v${v}/`;
      const map: Record<string, { url: string; name: string; icon: string }> = {
        'mac-x64':              { url: `${base}OpenHeaders-${v}-mac-x64.dmg`,     name: 'macOS Intel',          icon: '/assets/icons/apple.svg' },
        'mac-arm64':            { url: `${base}OpenHeaders-${v}-mac-arm64.dmg`,   name: 'macOS Apple Silicon',  icon: '/assets/icons/apple.svg' },
        'windows-x64':          { url: `${base}OpenHeaders-${v}-Setup.exe`,       name: 'Windows with Git',     icon: '/assets/icons/windows.svg' },
        'windows-x64-nogit':    { url: `${base}OpenHeaders-${v}-Setup-NoGit.exe`, name: 'Windows without Git',  icon: '/assets/icons/windows.svg' },
        'linux-appimage-x64':   { url: `${base}OpenHeaders-${v}-x64.AppImage`,    name: 'Linux AppImage x64',   icon: '/assets/icons/linux.svg' },
        'linux-appimage-arm64': { url: `${base}OpenHeaders-${v}-arm64.AppImage`,  name: 'Linux AppImage ARM64', icon: '/assets/icons/linux.svg' },
        'linux-deb-x64':        { url: `${base}open-headers_${v}_amd64.deb`,      name: 'Debian/Ubuntu x64',    icon: '/assets/icons/linux.svg' },
        'linux-deb-arm64':      { url: `${base}open-headers_${v}_arm64.deb`,      name: 'Debian/Ubuntu ARM64',  icon: '/assets/icons/linux.svg' },
        'linux-rpm-x64':        { url: `${base}open-headers-${v}.x86_64.rpm`,     name: 'Fedora/RHEL x64',      icon: '/assets/icons/linux.svg' },
        'linux-rpm-arm64':      { url: `${base}open-headers-${v}.aarch64.rpm`,    name: 'Fedora/RHEL ARM64',    icon: '/assets/icons/linux.svg' },
      };
      return map[variant || `${os}-${arch}`] || null;
    }

    function getAllDownloads() {
      return [
        getDownloadUrl('mac', 'arm64'), getDownloadUrl('mac', 'x64'),
        getDownloadUrl('windows', 'x64'), getDownloadUrl('windows', 'x64', 'windows-x64-nogit'),
        getDownloadUrl('linux-appimage', 'x64'), getDownloadUrl('linux-appimage', 'arm64'),
        getDownloadUrl('linux-deb', 'x64'), getDownloadUrl('linux-deb', 'arm64'),
        getDownloadUrl('linux-rpm', 'x64'), getDownloadUrl('linux-rpm', 'arm64'),
      ].filter(Boolean);
    }

    function getInstallInstructions(platform: string) {
      const v = latestVersion || '3.0.0';
      const certUrl = `https://github.com/OpenHeaders/open-headers-app/releases/download/v${v}/open-headers-ca.crt`;
      const map: Record<string, string> = {
        windows: `<h4>Installation Steps for Windows</h4><div class="warning-box"><strong>Certificate Required:</strong> You must install the certificate first.</div><ol><li><strong>Download & Install Certificate:</strong> <a href="${certUrl}" target="_blank">open-headers-ca.crt</a> — install to "Trusted Root Certification Authorities"</li><li><strong>Run the installer</strong></li><li><strong>Launch</strong> from Start menu</li></ol>`,
        mac: `<h4>Installation Steps for macOS</h4><ol><li>Open the downloaded .dmg file</li><li>Drag OpenHeaders to Applications</li><li>Launch from Applications or Spotlight</li></ol>`,
        'linux-appimage': `<h4>Installation Steps for Linux (AppImage)</h4><ol><li><code>chmod +x OpenHeaders-*.AppImage</code></li><li><code>sudo ./install-open-headers.sh</code></li><li>Launch from application menu</li></ol>`,
        'linux-deb': `<h4>Installation Steps for Debian/Ubuntu</h4><ol><li><code>sudo apt install ./open-headers_*.deb</code></li><li>Launch from application menu</li></ol>`,
        'linux-rpm': `<h4>Installation Steps for Fedora/RHEL</h4><ol><li><code>sudo rpm -i open-headers-*.rpm</code></li><li>Launch from application menu</li></ol>`,
        linux: `<h4>Installation Steps for Linux</h4><ul><li><strong>AppImage:</strong> Universal, no install</li><li><strong>.deb:</strong> Debian/Ubuntu</li><li><strong>.rpm:</strong> Fedora/RHEL</li></ul>`,
      };
      return map[platform] || map.linux;
    }

    async function fetchLatestVersion() {
      try {
        const res = await fetch('https://api.github.com/repos/OpenHeaders/open-headers-app/releases/latest');
        const data = await res.json();
        latestVersion = data.tag_name.replace('v', '');
      } catch { latestVersion = '3.0.0'; }
    }

    function escapeHtml(text: string) {
      const div = document.createElement('div');
      div.textContent = text || '';
      return div.innerHTML;
    }

    function displayError(msg: string) {
      document.querySelector('.join-card')!.innerHTML = `
        <div class="flex items-center justify-center gap-2 mb-8">
          <img src="/logo.svg" alt="OpenHeaders" width="40" height="40" loading="eager" />
          <span class="font-display font-bold text-xl text-tx">OpenHeaders</span>
        </div>
        <div class="text-center py-12">
          <h2 class="font-display text-xl font-bold text-tx mb-4">Invalid Invite</h2>
          <p class="text-tx-2 mb-8">${escapeHtml(msg)}</p>
          <a href="https://openheaders.io" class="btn-primary-join">Visit OpenHeaders</a>
        </div>`;
    }

    function displayWorkspaceInfo(data: any) {
      document.getElementById('workspace-info')!.innerHTML = `
        <h2 class="text-base font-semibold text-tx mb-3"><span class="text-tx-2 font-normal">Name:</span> ${escapeHtml(data.workspaceName)}</h2>
        <div class="detail-row"><span class="detail-label">Repository:</span><span class="detail-value">${escapeHtml(data.repoUrl)}</span></div>
        <div class="detail-row"><span class="detail-label">Branch:</span><span class="detail-value">${escapeHtml(data.branch || 'main')}</span></div>
        <div class="detail-row"><span class="detail-label">Config Path:</span><span class="detail-value">${escapeHtml(data.configPath || 'config/open-headers.json')}</span></div>
        ${data.inviterName ? `<div class="detail-row"><span class="detail-label">Invited by:</span><span class="detail-value">${escapeHtml(data.inviterName)}</span></div>` : ''}`;
    }

    async function displayDownloadOptions() {
      await fetchLatestVersion();
      const plat = detectPlatform();
      document.getElementById('detected-os')!.textContent = plat.display;

      let primary = null;
      if (plat.os === 'mac') primary = getDownloadUrl('mac', plat.arch);
      else if (plat.os === 'windows') primary = getDownloadUrl('windows', 'x64');
      else if (plat.os.includes('linux')) {
        if (plat.os === 'linux-deb') primary = getDownloadUrl('linux-deb', plat.arch);
        else if (plat.os === 'linux-rpm') primary = getDownloadUrl('linux-rpm', plat.arch);
        else primary = getDownloadUrl('linux-appimage', plat.arch);
      }

      if (primary) {
        const btn = document.getElementById('primary-download') as HTMLAnchorElement;
        const icon = document.getElementById('primary-icon') as HTMLImageElement;
        const text = document.getElementById('primary-text')!;
        btn.href = primary.url;
        icon.src = primary.icon;
        icon.classList.add('brightness-0', 'invert');
        const v = latestVersion || '3.0.0';
        text.innerHTML = `${primary.name} <span class="opacity-60">${v}</span>`;
        btn.setAttribute('download', '');
      }

      const all = getAllDownloads().filter(d => !primary || d.url !== primary.url);
      const v = latestVersion || '3.0.0';
      document.getElementById('other-downloads')!.innerHTML = all.map(opt =>
        `<a href="${opt.url}" class="download-option" download>
          <div class="info"><img src="${opt.icon}" alt="${opt.name}" width="16" height="16" loading="lazy"><span class="name">${opt.name}</span></div>
          <span class="size">${v}</span>
        </a>`
      ).join('');

      document.getElementById('download-section')!.classList.add('section-visible');

      let ip = plat.os;
      if (ip === 'linux' && primary) {
        if (primary.name.includes('AppImage')) ip = 'linux-appimage';
        else if (primary.name.includes('Debian')) ip = 'linux-deb';
        else if (primary.name.includes('Fedora')) ip = 'linux-rpm';
      }
      document.getElementById('install-instructions')!.innerHTML = getInstallInstructions(ip);
    }

    function tryOpenApp() {
      if (!inviteData) return;
      window.location.href = buildProtocolUrl(inviteData);
    }

    function checkIfAppInstalled() {
      if (!inviteData) return;
      const url = buildProtocolUrl(inviteData);
      const iframe = document.createElement('iframe');
      iframe.style.display = 'none';
      iframe.src = url;

      const handleBlur = () => {
        document.getElementById('no-app-section')!.style.display = 'none';
        document.getElementById('has-app-section')!.style.display = 'block';
        window.removeEventListener('blur', handleBlur);
        iframe.remove();
      };

      window.addEventListener('blur', handleBlur);
      setTimeout(() => { window.removeEventListener('blur', handleBlur); iframe.remove(); }, 1500);
      document.body.appendChild(iframe);
    }

    function init() {
      const params = new URLSearchParams(window.location.search);
      const payloadParam = params.get('payload');
      if (!payloadParam) { displayError('No invite found'); return; }

      try {
        let decoded;
        try {
          const compressed = Uint8Array.from(atob(payloadParam.replace(/-/g, '+').replace(/_/g, '/')), c => c.charCodeAt(0));
          decoded = JSON.parse((window as any).pako.ungzip(compressed, { to: 'string' }));
        } catch {
          try { decoded = JSON.parse(atob(payloadParam)); } catch { throw new Error('Invalid format'); }
        }

        if (decoded.action !== 'team-invite' || !decoded.data) { displayError('Invalid invite'); return; }
        inviteData = decoded.data;
        if (!inviteData?.workspaceName || !inviteData?.repoUrl) { displayError('Invalid invite'); return; }

        displayWorkspaceInfo(inviteData);
        displayDownloadOptions();
        checkIfAppInstalled();

        document.getElementById('already-installed-btn')?.addEventListener('click', tryOpenApp);
        document.getElementById('open-in-app-btn')?.addEventListener('click', (e) => {
          e.preventDefault();
          if (inviteData) window.location.href = buildProtocolUrl(inviteData);
        });
      } catch {
        displayError('Invalid invite');
      }
    }

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
    else init();
  </script>
</Base>

<style>
  .join-container {
    max-width: 700px; margin: 0 auto; padding: 2rem 20px;
    min-height: 100vh; display: flex; align-items: center; justify-content: center;
  }
  .join-card {
    background: var(--c-bg); border: 1px solid var(--c-bdhi); border-radius: 18px;
    padding: 2rem; width: 100%; max-height: calc(100vh - 4rem); overflow-y: auto;
    box-shadow: 0 20px 60px var(--c-shadow);
  }
  .workspace-details {
    background: var(--c-bg2); border: 1px solid var(--c-bd); border-radius: 12px;
    padding: 1rem; margin-bottom: 1.5rem;
  }
  .detail-row { display: flex; margin-bottom: .5rem; font-size: .875rem; }
  .detail-row:last-child { margin-bottom: 0; }
  .detail-label { min-width: 100px; color: var(--c-tx2); font-weight: 500; }
  .detail-value { color: var(--c-tx); word-break: break-all; }

  .action-section { margin-bottom: 1rem; display: none; }
  .section-visible { display: block !important; }
  .section-hidden { display: none !important; }

  .btn-primary-join {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 20px; border-radius: 6px;
    background: var(--c-accent); color: #fff; border: 1px solid var(--c-accent);
    font-size: .875rem; font-weight: 500; text-decoration: none;
    cursor: pointer; transition: all .2s;
  }
  .btn-primary-join:hover { background: var(--c-accenthi); border-color: var(--c-accenthi); }

  .already-installed-btn {
    padding: .75rem 1.25rem; background: transparent; color: var(--c-tx);
    border: 2px solid var(--c-bd); border-radius: 6px; font-size: .875rem;
    font-weight: 500; cursor: pointer; transition: all .3s;
    display: inline-flex; align-items: center; gap: .5rem; min-width: 280px;
    justify-content: center;
  }
  .already-installed-btn:hover { border-color: var(--c-accent); color: var(--c-accent); background: var(--c-bg2); }
  .btn-error { border-color: #ef4444 !important; color: #ef4444 !important; }

  .success-section { display: none; text-align: center; padding: 1.5rem; background: var(--c-successdim); border: 1px solid var(--c-successbd); border-radius: 12px; }
  .success-section p { margin-bottom: 1rem; color: var(--c-success); font-weight: 500; }

  .dl-other summary { cursor: pointer; list-style: none; color: var(--c-accent); font-size: .875rem; font-weight: 500; user-select: none; display: inline-flex; align-items: center; gap: .5rem; }
  .dl-other summary::-webkit-details-marker { display: none; }
  .dl-other summary::before { content: '\25B6'; display: inline-block; transition: transform .2s; font-size: .5rem; }
  .dl-other[open] summary::before { transform: rotate(90deg); }
  .dl-list { margin-top: .75rem; display: grid; gap: .375rem; max-height: 150px; overflow-y: auto; }

  .download-option {
    display: flex; align-items: center; justify-content: space-between;
    padding: .625rem .875rem; background: var(--c-bg2); border: 1px solid var(--c-bd);
    border-radius: 6px; text-decoration: none; color: var(--c-tx); font-size: .875rem; transition: all .2s;
  }
  .download-option:hover { border-color: var(--c-accent); background: var(--c-bg3); }
  .download-option .info { display: flex; align-items: center; gap: .5rem; }
  .download-option .name { font-weight: 500; }
  .download-option .size { color: var(--c-tx2); font-size: .8125rem; }

  .install-instructions { background: var(--c-accentdim); border: 1px solid var(--c-accentbd); border-radius: 12px; padding: 1rem; margin-top: .75rem; }
  .install-instructions :global(h4) { font-size: .9375rem; margin-bottom: .75rem; color: var(--c-tx); font-weight: 600; }
  .install-instructions :global(ol) { padding-left: 1.5rem; }
  .install-instructions :global(li) { margin-bottom: .375rem; color: var(--c-tx); font-size: .875rem; }
  .install-instructions :global(code) { background: var(--c-bg); padding: 2px 6px; border-radius: 4px; font-family: 'JetBrains Mono', monospace; font-size: .875rem; border: 1px solid var(--c-bd); }
  .warning-box { background: rgba(251,191,36,.1); border: 1px solid rgba(251,191,36,.3); padding: .75rem; margin-bottom: .75rem; border-radius: 6px; color: #FEBC2E; font-size: .875rem; }

  @media (max-width: 768px) {
    .join-container { padding: 1rem; }
    .join-card { padding: 1.5rem 1.25rem; }
    .detail-row { flex-direction: column; gap: .125rem; }
    .detail-label { min-width: unset; }
  }
</style>
